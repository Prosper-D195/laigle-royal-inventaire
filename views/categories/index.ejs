<div class="page-header">
    <h2>Gestion des Catégories</h2>
    <a href="/categories/creer" class="btn btn-primary">Pouvoir ajouter une catégorie</a>
</div>

<div class="grid-container">
    <% categories.forEach(categorie => { %>
       <div class="card-actions" style="display: flex; flex-direction: column; gap: 10px;">
    <div style="display: flex; gap: 10px;">
        <a href="/categories/<%= categorie.id %>" class="btn btn-info" style="flex: 1;">Voir les articles</a>
        <a href="/categories/<%= categorie.id %>/modifier" class="btn btn-warning" style="flex: 1;">Modifier</a>
    </div>
    
    <form action="/categories/<%= categorie.id %>/supprimer" method="POST" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette catégorie ?');" style="margin: 0;">
        <div style="display: flex; gap: 5px;">
            <input type="password" name="adminPassword" required placeholder="Code Secret" style="padding: 5px; width: 60%; border: 1px solid #cbd5e0; border-radius: 4px; font-size: 12px;">
            <button type="submit" class="btn" style="background-color: #e53e3e; color: white; flex: 1; padding: 5px; font-size: 12px;">Supprimer</button>
        </div>
    </form>
</div>
        </div>
    <% }) %>
</div>