<div class="form-container">
    <h2><%= title %></h2>

    <form action="<%= article ? '/articles/' + article.id + '/modifier' : '/articles/creer' %>" method="POST">
        
        <div class="form-group">
            <label for="nom">Nom de l'article :</label>
            <input type="text" id="nom" name="nom" value="<%= article ? article.nom : '' %>" required placeholder="Ex: Papaye Calina, Engrais NPK...">
        </div>

        <div class="form-group">
            <label for="categorie_id">Catégorie associée :</label>
            <select id="categorie_id" name="categorie_id" required style="padding: 10px; border-radius: 4px; border: 1px solid #cbd5e0; font-size: 16px;">
                <option value="" disabled <%= !article ? 'selected' : '' %>>-- Choisir une catégorie --</option>
                <% categories.forEach(cat => { %>
                    <option value="<%= cat.id %>" <%= article && article.categorie_id === cat.id ? 'selected' : '' %> >
                        <%= cat.nom %>
                    </option>
                <% }) %>
            </select>
        </div>

        <div class="form-group">
            <label for="prix">Prix unitaire (FCFA) :</label>
            <input type="number" id="prix" name="prix" min="0" step="0.01" value="<%= article ? article.prix : '' %>" required placeholder="Ex: 1500">
        </div>

        <div class="form-group">
            <label for="quantite">Quantité en stock :</label>
            <input type="number" id="quantite" name="quantite" min="0" value="<%= article ? article.quantite : '0' %>" required placeholder="Ex: 50">
        </div>

        <div class="form-group">
            <label for="description">Description :</label>
            <textarea id="description" name="description" rows="4" placeholder="Détails du produit..."><%= article ? article.description : '' %></textarea>
        </div>

        <% if (article) { %>
            <div class="form-group alert-field">
                <label for="adminPassword">🔒 Mot de passe Administrateur requis :</label>
                <input type="password" id="adminPassword" name="adminPassword" required placeholder="Entrez le code secret pour valider les changements">
            </div>
        <% } %>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a href="/articles" class="btn btn-secondary">Annuler</a>
        </div>
    </form>
</div>